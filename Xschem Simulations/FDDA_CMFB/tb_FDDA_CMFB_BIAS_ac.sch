value="
.param temp=25
.option savecurrents
.param W_1=88
.param W_2=88
.param W_3=88
.param W_4=14
.param W_5=28
.param W_6=176
.param W_7=14
.param W_8=176
.param L_1=1
.param L_2=1
.param L_3=1
.param L_4=1
.param L_5=1
.param L_6=1
.param L_7=1
.param L_8=1
.control
  save all
  op
  write tb_FDDA_CMFB_BIAS_ac.raw
.endc
"}
