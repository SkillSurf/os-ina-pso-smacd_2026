C {devices/code.sym} 440 -550 0 0 {name=TT_MODELS
only_toplevel=true
format="tcleval( @value )"
value="
** opencircuitdesign pdks install
.lib $::SKYWATER_MODELS/sky130.lib.spice tt
"
spice_ignore=false}
C {code.sym} 280 -550 0 0 {name="AC" only_toplevel=false
value="
.control
  save all
  ac dec 20 0.1 1G

  let vout = v(v_op) - v(v_on)
  let vin = (v(v_pp) - v(v_pn)) - (v(v_np) - v(v_nn))

  let gain = vout / vin
  let db_gain = db(gain)
  let deg_phase = 180*cph(v(vout))/pi

  meas ac gain_DC FIND db_gain AT=1

  meas ac gbw_freq WHEN db_gain=0 FALL=1
  let gbw_Mfreq = gbw_freq * 1e-6

  meas ac pm_deg FIND deg_phase AT=gbw_freq
  let pm = 180 + pm_deg

  plot db_gain deg_phase
  print gain_DC
  print gbw_Mfreq
  print pm
.endc
"}
C {devices/launcher.sym} 670 -450 0 0 {name=h15
descr="Annotate OP" 
tclcommand="set show_hidden_texts 1; xschem annotate_op"
}
